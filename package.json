{
  "name": "pict-cli",
  "version": "0.2.0",
  "description": "Node.js-friendly command-line tool for running PICT-style combinatorial test generation",
  "keywords": [
    "pict",
    "testing",
    "testing-tools",
    "test-case-generation",
    "combinatorial-testing",
    "pairwise",
    "pairwise-testing"
  ],
  "homepage": "https://github.com/takeyaqa/pict-cli#readme",
  "bugs": {
    "url": "https://github.com/takeyaqa/pict-cli/issues"
  },
  "license": "MIT",
  "author": "Takeshi Kishi",
  "files": [
    "bin"
  ],
  "bin": {
    "pict-cli": "bin/cli.js"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takeyaqa/pict-cli.git"
  },
  "scripts": {
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "node --test tests/e2e.spec.js"
  },
  "dependencies": {
    "@takeyaqa/pict-wasm": "3.7.4-wasm.18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": "^22 || ^24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "^10"
      }
    ]
  }
}
